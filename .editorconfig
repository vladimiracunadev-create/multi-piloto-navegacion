# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Markdown usa dos espacios finales para saltos de linea intencionales.
trim_trailing_whitespace = false

[*.py]
indent_size = 4

[*.ps1]
# Windows PowerShell 5.1 lee los .ps1 sin BOM como ANSI, asi que una tilde en el
# script saldria como mojibake al ejecutarlo. El BOM la mantiene legible.
charset = utf-8-bom
end_of_line = crlf
indent_size = 4
